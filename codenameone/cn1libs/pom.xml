    <groupId>com.baeldung.cn1tutorial</groupId>
    <artifactId>dailyroutine-cn1libs</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>dailyroutine-cn1libs</name>
    <profiles>
    <!-- Profile injected by install-cn1lib goal for NativeLogsReader cn1lib -->
<profile>
  <id>NativeLogsReader.cn1lib-cn1lib</id>
  <activation>
    <file><exists>${basedir}/NativeLogsReader/pom.xml</exists></file>
  </activation>  <modules><module>NativeLogsReader</module></modules>
</profile>
<profile>
  <id>NativeLogsReader.cn1lib-cn1lib-fromroot</id>
  <activation>
    <file><exists>${basedir}/cn1libs/NativeLogsReader/pom.xml</exists></file>
  </activation>  <modules><module>NativeLogsReader</module></modules>
</profile>

</profiles>
</project>